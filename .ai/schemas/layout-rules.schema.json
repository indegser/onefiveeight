{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LayoutRules",
  "type": "object",
  "required": ["version", "reference_basis", "rules"],
  "properties": {
    "version": { "type": "string" },
    "reference_basis": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "rule", "enforcement"],
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "rule": { "type": "string" },
          "enforcement": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
