{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BuildResult",
  "type": "object",
  "required": ["completed_tasks", "changed_files", "open_issues"],
  "properties": {
    "completed_tasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
