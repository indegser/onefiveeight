{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentMessage",
  "type": "object",
  "required": [
    "agent",
    "run_id",
    "timestamp",
    "status",
    "summary",
    "blocking",
    "needs_human",
    "output",
    "issues"
  ],
  "properties": {
    "agent": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "blocked", "failed"]
    },
    "summary": {
      "type": "string"
    },
    "blocking": {
      "type": "boolean"
    },
    "needs_human": {
      "type": "boolean"
    },
    "output": {
      "type": "object"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "message": {
            "type": "string"
          },
          "file": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
