{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifyResult",
  "type": "object",
  "required": ["checks", "passed", "blocking_issues"],
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "details": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "passed": {
      "type": "boolean"
    },
    "visual_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "details"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "details": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
