#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" != "--run-id" ] || [ -z "${2:-}" ]; then
  echo "Usage: actions/route-and-validate --run-id <run_id>" >&2
  exit 1
fi

run_id="$2"
run_dir=".ai/runs/$run_id"

if [ ! -d "$run_dir" ]; then
  echo "Run directory not found: $run_dir" >&2
  exit 1
fi

npm run ai:validate -- --run-id "$run_id"
echo "ai:route is advisory only; use \$ai-team-supervisor to update run.json." >&2
npm run ai:route -- --run-id "$run_id"
