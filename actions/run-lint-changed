#!/usr/bin/env bash
set -euo pipefail

run_id=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --run-id)
      run_id="${2:-}"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [ -z "$run_id" ]; then
  echo "Usage: actions/run-lint-changed --run-id <run_id> [file ...]" >&2
  exit 1
fi

run_dir=".ai/runs/$run_id"

if [ ! -d "$run_dir" ]; then
  echo "Run directory not found: $run_dir" >&2
  exit 1
fi

declare -a files=()

if [ "$#" -gt 0 ]; then
  files=("$@")
else
  while IFS= read -r file; do
    files+=("$file")
  done < <(
    {
      git diff --name-only --diff-filter=ACMRT
      git ls-files --others --exclude-standard
    } | rg '\.(ts|tsx|js|jsx|mjs|cjs)$' | sort -u
  )
fi

if [ "${#files[@]}" -eq 0 ]; then
  echo "No changed lintable files for run $run_id."
  exit 0
fi

echo "Linting changed files for run $run_id:"
printf ' - %s\n' "${files[@]}"
npx eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs "${files[@]}"
