#!/usr/bin/env bash
set -euo pipefail

run_id=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --run-id)
      run_id="${2:-}"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [ -z "$run_id" ] || [ "$#" -lt 1 ]; then
  echo "Usage: actions/capture-screenshot --run-id <run_id> <url> [output-path] [load-state]" >&2
  exit 1
fi

run_dir=".ai/runs/$run_id"

if [ ! -d "$run_dir" ]; then
  echo "Run directory not found: $run_dir" >&2
  exit 1
fi

url="$1"
output_path="${2:-$run_dir/evidence/screenshot.png}"
load_state="${3:-networkidle}"

if [[ "$output_path" = /* ]]; then
  normalized_output_path="$output_path"
else
  normalized_output_path="$PWD/$output_path"
fi

mkdir -p "$(dirname "$normalized_output_path")"

agent-browser open "$url"
agent-browser wait --load "$load_state"
agent-browser screenshot "$normalized_output_path"
