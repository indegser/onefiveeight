{
  "$schema": "../../.ai/schemas/design-tokens.schema.json",
  "version": "0.3.0",
  "status": "reference-template",
  "binding": {
    "source": "design-rule-engine-profile-selection",
    "notes": [
      "This file describes token categories for future profile-specific token work.",
      "It is not a runtime source of truth and should not be copied into src/app/globals.css by default.",
      "Rendered web work should select a profile/register through aesthetic-profile.json and theme-usage.md before introducing or changing runtime tokens.",
      "Use semantic Tailwind/shadcn utilities first; add new runtime tokens only through an approved browser-verified token task."
    ]
  },
  "tokens": {
    "spacing": {
      "scale_type": "modular",
      "base_unit": 4,
      "steps": [4, 8, 12, 16, 24, 32, 48, 64],
      "usage": {
        "micro": 4,
        "tight": 8,
        "compact": 12,
        "default": 16,
        "section": 24,
        "group": 32,
        "page": 48,
        "hero": 64
      },
      "notes": [
        "Use 12, 24, and 32 as the primary editorial rhythm steps for dense working surfaces.",
        "Prefer finite scale choices over one-off spacing nudges."
      ]
    },
    "typography": {
      "families": {
        "body": "var(--font-geist-sans)",
        "display": "var(--font-geist-sans)",
        "mono": "var(--font-geist-mono)"
      },
      "size_scale": [12, 14, 16, 18, 24, 32, 48],
      "line_height_scale": {
        "display": 1.05,
        "dense": 1.2,
        "default": 1.5,
        "relaxed": 1.7
      },
      "tracking_scale": {
        "meta": 0.08,
        "label": 0.12,
        "default": 0,
        "display_sm": -0.03,
        "display_lg": -0.04
      },
      "weight_scale": {
        "regular": 400,
        "medium": 500,
        "semibold": 600
      },
      "weight_strategy": "prefer weight contrast before large size jumps"
    },
    "color": {
      "palette_mode": "profile-selected-semantic",
      "roles": {
        "background": "bg-background",
        "surface": "bg-card",
        "surface_alt": "bg-muted",
        "text_primary": "text-foreground",
        "text_secondary": "text-muted-foreground",
        "text_muted": "text-muted-foreground",
        "accent": "bg-primary",
        "accent_soft": "bg-muted",
        "success": "semantic-status-success",
        "warning": "semantic-status-warning",
        "danger": "text-destructive",
        "border": "border-border"
      },
      "notes": [
        "Do not hard-code profile color values in globals.css by default.",
        "Translate profile decisions into semantic Tailwind/shadcn utilities unless a runtime-token task is explicitly approved.",
        "Accent usage should carry action, state, navigation, or subject meaning."
      ]
    },
    "radius": {
      "scale": [0, 4, 8, 12],
      "notes": [
        "Prefer restrained radius values."
      ]
    },
    "shadow": {
      "levels": [
        "none",
        "0 1px 2px rgba(31, 28, 25, 0.04)",
        "0 4px 12px rgba(31, 28, 25, 0.06)"
      ],
      "notes": [
        "Shadows should be rare, soft, and supportive rather than brand-defining."
      ]
    },
    "grid": {
      "type": "modular-column-grid",
      "columns": 12,
      "gutter": 24,
      "container": {
        "sm": 640,
        "md": 768,
        "lg": 1024,
        "xl": 1280,
        "2xl": 1536
      },
      "baseline_rhythm": "required"
    }
  }
}
