{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LeadSheetExtract",
  "type": "object",
  "required": ["pages", "unresolved"],
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_id", "asset_path", "tokens"],
        "properties": {
          "page_id": { "type": "string" },
          "asset_path": { "type": "string" },
          "tokens": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "token_id",
                "type",
                "raw_text",
                "bbox",
                "confidence"
              ],
              "properties": {
                "token_id": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": [
                    "section_label",
                    "chord",
                    "repeat",
                    "jump",
                    "time_signature",
                    "barline",
                    "note",
                    "other"
                  ]
                },
                "raw_text": { "type": "string" },
                "bbox": {
                  "type": "object",
                  "required": ["x", "y", "width", "height"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "width": { "type": "number" },
                    "height": { "type": "number" }
                  },
                  "additionalProperties": false
                },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "unresolved": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
