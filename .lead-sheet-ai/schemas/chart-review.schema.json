{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LeadSheetChartReview",
  "type": "object",
  "required": ["approved", "findings", "unresolved_items", "next_steps"],
  "properties": {
    "approved": { "type": "boolean" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "message": { "type": "string" },
          "area": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
