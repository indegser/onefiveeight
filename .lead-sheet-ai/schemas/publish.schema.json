{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LeadSheetPublish",
  "type": "object",
  "required": ["status", "target_ref", "published_artifacts", "notes"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ready", "published", "withheld"]
    },
    "target_ref": { "type": "string" },
    "published_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
