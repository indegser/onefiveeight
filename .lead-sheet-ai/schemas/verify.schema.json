{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LeadSheetVerify",
  "type": "object",
  "required": ["checks", "passed", "blocking_issues", "review_required_count"],
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "details": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "passed": { "type": "boolean" },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "review_required_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
