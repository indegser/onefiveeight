{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LeadSheetRun",
  "type": "object",
  "required": [
    "run_id",
    "goal",
    "revision",
    "phase",
    "status",
    "inputs",
    "artifacts",
    "approvals",
    "blockers",
    "uncertainties",
    "history"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "goal": { "type": "string" },
    "revision": { "type": "integer", "minimum": 1 },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "preprocess",
        "extract",
        "align",
        "verify",
        "review",
        "publish",
        "done"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "blocked", "needs_human", "done"]
    },
    "next_agent": {
      "type": "string",
      "enum": [
        "intake-supervisor",
        "preprocessor",
        "extractor",
        "aligner",
        "verifier",
        "chart-reviewer",
        "publisher",
        "human",
        "none"
      ]
    },
    "inputs": {
      "type": "object",
      "required": [
        "source_ref",
        "score_id",
        "constraints",
        "accuracy_priority"
      ],
      "properties": {
        "source_ref": { "type": "string" },
        "score_id": { "type": ["string", "null"] },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "accuracy_priority": { "type": "string", "enum": ["max"] }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": [
        "intake",
        "preprocess",
        "extract",
        "align",
        "verify",
        "publish"
      ],
      "properties": {
        "intake": { "type": "string" },
        "preprocess": { "type": "string" },
        "extract": { "type": "string" },
        "align": { "type": "string" },
        "verify": { "type": "string" },
        "publish": { "type": "string" }
      },
      "additionalProperties": false
    },
    "approvals": {
      "type": "object",
      "required": ["human_review", "publish"],
      "properties": {
        "human_review": { "type": "boolean" },
        "publish": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "uncertainties": {
      "type": "array",
      "items": { "type": "string" }
    },
    "refinement_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "note", "target_agent"],
        "properties": {
          "at": { "type": "string" },
          "note": { "type": "string" },
          "target_agent": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "event"],
        "properties": {
          "at": { "type": "string" },
          "event": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
